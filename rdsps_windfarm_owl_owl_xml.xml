    <Literal xml:lang="en">Asset</Literal>
  </AnnotationAssertion>
  <AnnotationAssertion>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#comment"/>
    <IRI>http://example.org/rdsps#Asset</IRI>
    <Literal xml:lang="en">Generic asset superclass (equipment, sensors, systems).</Literal>
  </AnnotationAssertion>

  <Declaration>
