<?xml version="1.0" encoding="UTF-8"?>
<Ontology IRI="http://example.org/rdsps"
          xmlns="http://www.w3.org/2002/07/owl#"
          xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
          xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
          xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <!-- Basic annotations -->
  <Annotation>
    <AnnotationProperty IRI="http://www.w3.org/2000/01/rdf-schema#label"/>
    <Literal xml:lang="en">RDS-PS Example Ontology (Minimal)</Literal>
  </Annotation>

  <!-- Class declarations -->
  <Declaration><Class IRI="http://example.org/rdsps#Asset"/></Declaration>
  <Declaration><Class IRI="http://example.org/rdsps#Location"/></Declaration>
  <Declaration><Class IRI="http://example.org/rdsps#ProductAspect"/></Declaration>

  <!-- Subclass axioms -->
  <SubClassOf>
    <Class IRI="http://example.org/rdsps#Location"/>
    <Class IRI="http://example.org/rdsps#Asset"/>
  </SubClassOf>

  <!-- Object property declaration -->
  <Declaration><ObjectProperty IRI="http://example.org/rdsps#locatedIn"/></Declaration>
  <ObjectPropertyDomain>
    <ObjectProperty IRI="http://example.org/rdsps#locatedIn"/>
    <Class IRI="http://example.org/rdsps#Asset"/>
  </ObjectPropertyDomain>
  <ObjectPropertyRange>
    <ObjectProperty IRI="http://example.org/rdsps#locatedIn"/>
    <Class IRI="http://example.org/rdsps#Location"/>
  </ObjectPropertyRange>

  <!-- Datatype property declaration -->
  <Declaration><DatatypeProperty IRI="http://example.org/rdsps#hasRDSDesignation"/></Declaration>
  <DataPropertyDomain>
    <DatatypeProperty IRI="http://example.org/rdsps#hasRDSDesignation"/>
    <Class IRI="http://example.org/rdsps#Asset"/>
  </DataPropertyDomain>
  <DataPropertyRange>
    <DatatypeProperty IRI="http://example.org/rdsps#hasRDSDesignation"/>
    <Datatype IRI="http://www.w3.org/2001/XMLSchema#string"/>
  </DataPropertyRange>

  <!-- Example individuals -->
  <Declaration><NamedIndividual IRI="http://example.org/rdsps#WF01"/></Declaration>
  <ClassAssertion>
    <Class IRI="http://example.org/rdsps#Location"/>
    <NamedIndividual IRI="http://example.org/rdsps#WF01"/>
  </ClassAssertion>
  <DataPropertyAssertion>
    <DataProperty IRI="http://example.org/rdsps#hasRDSDesignation"/>
    <NamedIndividual IRI="http://example.org/rdsps#WF01"/>
    <Literal xml:datatype="http://www.w3.org/2001/XMLSchema#string">+WF01</Literal>
  </DataPropertyAssertion>

  <Declaration><NamedIndividual IRI="http://example.org/rdsps#TR01"/></Declaration>
  <ClassAssertion>
    <Class IRI="http://example.org/rdsps#ProductAspect"/>
    <NamedIndividual IRI="http://example.org/rdsps#TR01"/>
  </ClassAssertion>
  <ObjectPropertyAssertion>
    <ObjectProperty IRI="http://example.org/rdsps#locatedIn"/>
    <NamedIndividual IRI="http://example.org/rdsps#TR01"/>
    <NamedIndividual IRI="http://example.org/rdsps#WF01"/>
  </ObjectPropertyAssertion>
  <DataPropertyAssertion>
    <DataProperty IRI="http://example.org/rdsps#hasRDSDesignation"/>
    <NamedIndividual IRI="http://example.org/rdsps#TR01"/>
    <Literal xml:datatype="http://www.w3.org/2001/XMLSchema#string">+WF01 =DIS -TR01</Literal>
  </DataPropertyAssertion>

</Ontology>